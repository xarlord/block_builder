# Auto detect text files and perform LF normalization
* text=auto

# Kotlin / Java / Gradle — always LF
*.kt text eol=lf
*.java text eol=lf
*.kts text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.xml text eol=lf

# Web / assets
*.json text eol=lf
*.md text eol=lf
*.svg text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Scripts
*.sh text eol=lf

# Binary — don't touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.apk binary
*.jar binary
*.zip binary
